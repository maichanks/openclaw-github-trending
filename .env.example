# GitHub Trending Notifier 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# GitHub Personal Access Token
# 权限：public_repo 即可
# 获取地址：https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# OpenRouter API Key
# 获取地址：https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# 通知渠道：telegram / feishu / discord
NOTIFY_CHANNEL=telegram

# 通知目标（格式依赖渠道）
# Telegram: <bot_token>:<chat_id>
# Feishu: https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
# Discord: https://discord.com/api/webhooks/xxxxx/yyyyy
NOTIFY_TARGET=your_target_here

# 可选：最多推送的仓库数量（默认：5）
# MAX_REPOS=5

# 可选：使用的 OpenRouter 模型（默认：openai/gpt-4o-mini）
# 推荐选项：
# - openai/gpt-4o-mini（快速、经济）
# - anthropic/claude-3.5-sonnet（高质量）
# - google/gemini-2.0-flash-001（最快）
# - meta-llama/llama-3.3-70b-instruct（免费）
# OPENROUTER_MODEL=openai/gpt-4o-mini
