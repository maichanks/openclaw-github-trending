# OpenClaw GitHub Trending Notifier - Environment Configuration
# Copy this file to .env and fill in your values

# Notification channel (feishu, telegram, discord, slack)
NOTIFY_CHANNEL=feishu

# Target user or chat ID
# For Feishu: open_id (e.g., "ou_xxxxxxxx")
# For Telegram: chat ID (numeric)
NOTIFY_TARGET=ou_OPEN_ID

# OpenRouter API key (optional, for AI summarization)
# Get yours at https://openrouter.ai
OPENROUTER_API_KEY=

# GitHub token (optional, for higher rate limits)
# GITHUB_TOKEN=

# Filter preferences
FILTER_LANGUAGES=  # e.g., "en,zh" (leave empty for all)
MIN_STARS=100      # Minimum stars to include
SINCE=1           # Days back (1 = today, 7 = last week)
